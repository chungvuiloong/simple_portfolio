---
import Layout from '../layouts/Layout.astro';
import Portfolio from '@sections/Portfolio.tsx';
import Work from '@sections/Work.tsx';
import Profile from '@sections/Profile.tsx';
import Contact from '@sections/Contact.tsx';
import Tech from '@sections/Tech.tsx';
import { GraphQLClient } from "graphql-request";

// Create a new GraphQL client with the Hygraph endpoint
const client = new GraphQLClient(import.meta.env.ASTRO_HYGRAPH_ENDPOINT);
// Declare Pages type
type Pages = {
  pages: {
    title: string;
    slug: string;
    body: {
      text: string;
    };
  }[];
};
// Fetch the data via the GraphQL query
const { pages }: Pages = await client.request(`
  query Pages {
    pages {
      title
      slug
      body {
        text
      }
    }
  }
`);

---

<Layout title="MrJay's Simple Portfolio">
	<main>
        <Profile client:idle />
        <Portfolio client:idle />
        <!-- <Tech /> -->
        <Work />
        <Tech client:idle />
